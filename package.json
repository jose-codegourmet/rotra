{
  "name": "rotra",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "db:generate": "pnpm --filter @rotra/db db:generate",
    "db:push": "pnpm --filter @rotra/db db:push",
    "db:migrate": "pnpm --filter @rotra/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @rotra/db db:migrate:deploy",
    "db:migrate:reset": "pnpm --filter @rotra/db db:migrate:reset",
    "db:studio": "pnpm --filter @rotra/db db:studio",
    "db:seed": "pnpm --filter @rotra/db db:seed",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "turbo": "latest",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "dependencies": {
    "shadcn": "^4.1.2"
  }
}
