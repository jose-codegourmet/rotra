model Club {
  id          String  @id @default(uuid()) @db.Uuid
  ownerId     String  @map("owner_id") @db.Uuid
  name        String
  description String?
  avatarUrl   String? @map("avatar_url")

  /// Primary venue / city for cards and discovery (optional; set when minted from an application).
  locationCity  String? @map("location_city")
  locationVenue String? @map("location_venue")

  status ClubStatus @default(active)

  autoApprove       Boolean @default(false) @map("auto_approve")
  inviteLinkEnabled Boolean @default(true) @map("invite_link_enabled")
  inviteToken       String? @unique @map("invite_token")
  inviteTokenCreatedAt DateTime? @map("invite_token_created_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner            Profile                    @relation("ClubOwner", fields: [ownerId], references: [id])
  members          ClubMember[]
  joinRequests     ClubJoinRequest[]
  blacklist        ClubBlacklist[]
  auditLog         ClubMembershipAuditLog[]
  queueSessions    QueueSession[]
  sandbaggingFlags SandbaggingFlag[]
  mintedFromApplication ClubApplication?      @relation("ClubMintedFromApplication")

  @@index([ownerId], map: "idx_clubs_owner_id")
  @@index([inviteToken], map: "idx_clubs_invite_token")
  @@index([status], map: "idx_clubs_status")
  @@map("clubs")
}

model ClubMember {
  id        String @id @default(uuid()) @db.Uuid
  clubId    String @map("club_id") @db.Uuid
  playerId  String @map("player_id") @db.Uuid
  role      ClubRole       @default(member)
  status    MemberStatus   @default(active)
  joinedAt  DateTime       @default(now()) @map("joined_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Profile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
  @@index([clubId], map: "idx_club_members_club_id")
  @@index([playerId], map: "idx_club_members_player_id")
  @@index([status], map: "idx_club_members_status")
  @@index([role], map: "idx_club_members_role")
  @@map("club_members")
}

model ClubJoinRequest {
  id        String @id @default(uuid()) @db.Uuid
  clubId    String @map("club_id") @db.Uuid
  playerId  String @map("player_id") @db.Uuid
  method    JoinMethod
  status    JoinRequestStatus @default(pending)
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Profile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([clubId], map: "idx_join_requests_club_id")
  @@index([playerId], map: "idx_join_requests_player_id")
  @@index([status], map: "idx_join_requests_status")
  @@map("club_join_requests")
}

model ClubBlacklist {
  id         String @id @default(uuid()) @db.Uuid
  clubId     String @map("club_id") @db.Uuid
  playerId   String @map("player_id") @db.Uuid
  note       String?
  createdBy  String @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player  Profile @relation("BlacklistPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  creator Profile @relation("BlacklistCreatedBy", fields: [createdBy], references: [id])

  @@unique([clubId, playerId])
  @@index([clubId], map: "idx_club_blacklist_club_id")
  @@index([playerId], map: "idx_club_blacklist_player_id")
  @@map("club_blacklist")
}

model ClubMembershipAuditLog {
  id          String @id @default(uuid()) @db.Uuid
  clubId      String @map("club_id") @db.Uuid
  playerId    String @map("player_id") @db.Uuid
  action      MembershipAction
  performedBy String @map("performed_by") @db.Uuid
  note        String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  club      Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player    Profile @relation("AuditPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  performer Profile @relation("AuditPerformedBy", fields: [performedBy], references: [id])

  @@index([clubId], map: "idx_audit_log_club_id")
  @@index([playerId], map: "idx_audit_log_player_id")
  @@index([createdAt(sort: Desc)], map: "idx_audit_log_created_at")
  @@map("club_membership_audit_log")
}

/// Player-submitted request to create a new club; mints `clubs` on admin approval.
model ClubApplication {
  id        String @id @default(uuid()) @db.Uuid
  playerId  String @map("player_id") @db.Uuid

  clubName    String @map("club_name")
  description String
  intent      String

  locationCity  String @map("location_city")
  locationVenue String @map("location_venue")
  venueAddress  String @map("venue_address")

  facebookPageUrl    String? @map("facebook_page_url")
  facebookProfileUrl String? @map("facebook_profile_url")
  contactNumber        String? @map("contact_number")

  expectedPlayerCount ExpectedPlayerBucket @map("expected_player_count")
  additionalNotes     String? @map("additional_notes")

  status ApplicationStatus @default(pending)

  rejectionReason ApplicationRejectionReason? @map("rejection_reason")
  reviewNote      String? @map("review_note")
  reviewedById    String? @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at") @db.Timestamptz(6)

  resultingClubId String? @unique @map("resulting_club_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  player        Profile  @relation("ClubApplicationPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  reviewedBy    Profile? @relation("ClubApplicationReviewedBy", fields: [reviewedById], references: [id])
  resultingClub Club?    @relation("ClubMintedFromApplication", fields: [resultingClubId], references: [id])

  @@index([playerId], map: "idx_club_applications_player_id")
  @@index([status], map: "idx_club_applications_status")
  @@index([createdAt(sort: Desc)], map: "idx_club_applications_created")
  @@map("club_applications")
}
