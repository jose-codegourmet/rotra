// This is the single source of truth for the ROTRA database schema.
// All apps import types from @rotra/db — never define DB types elsewhere.
//
// Schema is split across *.prisma files in this directory; Prisma merges them.
//
// Supabase / Postgres notes (see docs/database/):
// - profiles.id references auth.users(id) ON DELETE CASCADE in real DDL; that FK is NOT modeled here
//   so Prisma migrate/push does not require the auth schema.
// - CHECK constraints (scores 1–5, reviewer_id != reviewee_id, session schedule rules, etc.) belong in SQL migrations.
// - RLS and triggers: docs/database/09_rls_and_realtime.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Models will be added here as features are built out.
