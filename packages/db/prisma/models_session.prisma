model QueueSession {
  id      String @id @default(uuid()) @db.Uuid
  clubId  String @map("club_id") @db.Uuid
  hostId  String @map("host_id") @db.Uuid

  origin        SessionOrigin
  scheduleType  ScheduleType? @map("schedule_type")

  status     SessionStatus     @default(draft)
  visibility SessionVisibility @default(club_members)

  location  String
  address   String?
  dateTime  DateTime @map("date_time") @db.Timestamptz(6)
  endTime   DateTime? @map("end_time") @db.Timestamptz(6)

  numCourts         Int @map("num_courts")
  playersPerCourt   Int @map("players_per_court")
  // GENERATED ALWAYS AS (num_courts * players_per_court) STORED — enforce in SQL; Prisma reads only.
  totalSlots        Int     @default(dbgenerated("(num_courts * players_per_court)")) @map("total_slots")

  matchFormat                 MatchFormat @default(best_of_1) @map("match_format")
  scoreLimit                  Int         @default(21) @map("score_limit")
  matchDurationEstimateMinutes Int        @default(15) @map("match_duration_estimate_minutes")

  shuttleType         String?   @map("shuttle_type")
  shuttleCostPerTube  Decimal?  @map("shuttle_cost_per_tube") @db.Decimal(10, 2)
  shuttlesUsed        Int       @default(0) @map("shuttles_used")
  courtCost           Decimal?  @map("court_cost") @db.Decimal(10, 2)
  markupType          MarkupType? @map("markup_type")
  markupAmount        Decimal?  @map("markup_amount") @db.Decimal(10, 2)

  smartMonitorThreshold     Decimal @default(0.90) @map("smart_monitor_threshold") @db.Decimal(3, 2)
  attendanceWindowMinutes   Int     @default(15) @map("attendance_window_minutes")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  host   Profile @relation(fields: [hostId], references: [id])

  registrations   SessionRegistration[]
  matches         Match[]
  expTransactions ExpTransaction[]

  @@index([clubId], map: "idx_queue_sessions_club_id")
  @@index([hostId], map: "idx_queue_sessions_host_id")
  @@index([status], map: "idx_queue_sessions_status")
  @@index([dateTime], map: "idx_queue_sessions_date_time")
  @@index([origin], map: "idx_queue_sessions_origin")
  @@index([scheduleType], map: "idx_queue_sessions_schedule")
  @@map("queue_sessions")
}

model SessionRegistration {
  id         String @id @default(uuid()) @db.Uuid
  sessionId  String @map("session_id") @db.Uuid
  playerId   String @map("player_id") @db.Uuid

  admissionStatus AdmissionStatus @default(waitlisted) @map("admission_status")
  waitlistPosition Int?           @map("waitlist_position")
  joinMethod       JoinSessionMethod @default(app) @map("join_method")

  playerStatus   PlayerSessionStatus @default(not_arrived) @map("player_status")
  paymentStatus  PaymentStatus     @default(unpaid) @map("payment_status")
  paymentAmount  Decimal           @default(0) @map("payment_amount") @db.Decimal(10, 2)
  perPlayerCost  Decimal?          @map("per_player_cost") @db.Decimal(10, 2)

  registeredAt DateTime @default(now()) @map("registered_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  session QueueSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player  Profile      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, playerId])
  @@index([sessionId], map: "idx_session_reg_session_id")
  @@index([playerId], map: "idx_session_reg_player_id")
  @@index([admissionStatus], map: "idx_session_reg_admission")
  @@index([playerStatus], map: "idx_session_reg_player_status")
  @@index([paymentStatus], map: "idx_session_reg_payment")
  @@index([sessionId, waitlistPosition], map: "idx_session_reg_waitlist")
  @@map("session_registrations")
}
