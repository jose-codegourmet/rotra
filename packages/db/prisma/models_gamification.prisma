model ExpTransaction {
  id        String @id @default(uuid()) @db.Uuid
  playerId  String @map("player_id") @db.Uuid
  amount    Int
  reason    ExpReason
  matchId   String? @map("match_id") @db.Uuid
  sessionId String? @map("session_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  player  Profile       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match   Match?        @relation(fields: [matchId], references: [id], onDelete: SetNull)
  session QueueSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([playerId], map: "idx_exp_transactions_player_id")
  @@index([matchId], map: "idx_exp_transactions_match_id")
  @@index([sessionId], map: "idx_exp_transactions_session_id")
  @@index([reason], map: "idx_exp_transactions_reason")
  @@index([createdAt(sort: Desc)], map: "idx_exp_transactions_created_at")
  @@map("exp_transactions")
}

model MmrTransaction {
  id        String @id @default(uuid()) @db.Uuid
  playerId  String @map("player_id") @db.Uuid
  amount    Int
  reason    MmrReason
  matchId   String @map("match_id") @db.Uuid
  preMmr    Int    @map("pre_mmr")
  postMmr   Int    @map("post_mmr")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  player Profile @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([playerId], map: "idx_mmr_transactions_player_id")
  @@index([matchId], map: "idx_mmr_transactions_match_id")
  @@index([createdAt(sort: Desc)], map: "idx_mmr_transactions_created_at")
  @@map("mmr_transactions")
}

model RankingTierConfig {
  id          String  @id @default(uuid()) @db.Uuid
  tierName    String  @unique @map("tier_name")
  label       String
  minExp      Int     @map("min_exp")
  badgeLabel  String  @map("badge_label")
  sortOrder   Int     @default(0) @map("sort_order")
  updatedById String? @map("updated_by") @db.Uuid
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  updatedBy Profile? @relation("RankingTierUpdatedBy", fields: [updatedById], references: [id])

  @@map("ranking_tier_config")
}

model SandbaggingFlag {
  id             String @id @default(uuid()) @db.Uuid
  playerId       String @map("player_id") @db.Uuid
  clubId         String? @map("club_id") @db.Uuid
  reason         String
  status         FlagStatus @default(active)
  resolvedById   String? @map("resolved_by") @db.Uuid
  resolvedAt     DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolutionNote String?   @map("resolution_note")
  detectedAt     DateTime @default(now()) @map("detected_at") @db.Timestamptz(6)

  player   Profile @relation("SandbaggingPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  club     Club?   @relation(fields: [clubId], references: [id], onDelete: SetNull)
  resolvedBy Profile? @relation("SandbaggingResolvedBy", fields: [resolvedById], references: [id])

  @@index([playerId], map: "idx_sandbagging_player_id")
  @@index([status], map: "idx_sandbagging_status")
  @@index([clubId], map: "idx_sandbagging_club_id")
  @@map("sandbagging_flags")
}
