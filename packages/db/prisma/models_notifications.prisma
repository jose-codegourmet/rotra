model Notification {
  id           String @id @default(uuid()) @db.Uuid
  recipientId  String @map("recipient_id") @db.Uuid
  type         NotificationType
  severity     NotificationSeverity @default(info)
  title        String
  body         String
  isRead       Boolean   @default(false) @map("is_read")
  readAt       DateTime? @map("read_at") @db.Timestamptz(6)
  relatedEntityType String? @map("related_entity_type")
  relatedEntityId   String? @map("related_entity_id") @db.Uuid
  scheduledAt  DateTime? @map("scheduled_at") @db.Timestamptz(6)
  sentAt       DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  broadcastId String? @map("broadcast_id") @db.Uuid

  recipient Profile @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  broadcast NotificationBroadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)

  @@index([recipientId], map: "idx_notifications_recipient_id")
  @@index([recipientId, isRead], map: "idx_notifications_is_read")
  @@index([scheduledAt], map: "idx_notifications_scheduled_at")
  @@index([type], map: "idx_notifications_type")
  @@index([createdAt(sort: Desc)], map: "idx_notifications_created_at")
  @@index([broadcastId], map: "idx_notifications_broadcast_id")
  @@map("notifications")
}

model NotificationBroadcast {
  id                   String @id @default(uuid()) @db.Uuid
  notificationType     NotificationType @map("notification_type")
  adminNotificationType AdminNotificationType @map("admin_notification_type")
  severity             NotificationSeverity @default(info)
  title                String
  body                 String
  appScopes            String[] @map("app_scopes")
  tagSlugs             String[] @map("tag_slugs")
  recipientCount       Int      @default(0) @map("recipient_count")
  relatedEntityType    String? @map("related_entity_type")
  relatedEntityId      String? @map("related_entity_id") @db.Uuid
  targetUrl            String? @map("target_url")
  scheduledAt          DateTime? @map("scheduled_at") @db.Timestamptz(6)
  createdById          String? @map("created_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy           Profile? @relation("BroadcastsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  notifications       Notification[]
  adminNotifications  AdminNotification[]

  @@index([createdAt(sort: Desc)], map: "idx_notification_broadcasts_created")
  @@index([createdById], map: "idx_notification_broadcasts_created_by")
  @@map("notification_broadcasts")
}
