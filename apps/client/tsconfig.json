{
	"extends": "@rotra/config/tsconfig",
	"compilerOptions": {
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"],
			"@rotra/legal-content": ["../../packages/legal-content/src/index.ts"]
		},
		"allowJs": true,
		"noEmit": true
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
